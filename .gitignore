# Ignore all dotfiles/dotdirs (session/editor/tool state, e.g. .claude/)
# except .gitignore itself, which must stay tracked.
.*
!.gitignore

# Ignore all Markdown files except README.md
*.md
!README.md


# Python bytecode
__pycache__/
*.pyc

# Generated outputs
output/
output_backup/
output_backup2/

# per commit tests, temp
tests/
